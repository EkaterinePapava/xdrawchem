#!/usr/bin/make -f
# Debian rules file for xdrawchem
# Uses debhelper 13 + cmake buildsystem

export DH_VERBOSE = 1
export DEB_BUILD_MAINT_OPTIONS = hardening=+all
# tst_smiles requires a Qt platform plugin for QApplication
export QT_QPA_PLATFORM = offscreen

%:
	dh $@ --buildsystem=cmake --builddirectory=build-deb

override_dh_auto_configure:
	dh_auto_configure -- \
		-DCMAKE_BUILD_TYPE=RelWithDebInfo \
		-DRINGHOME=/usr/share/xdrawchem

override_dh_auto_test:
	cd build-deb && ctest --output-on-failure -j$(nproc)

override_dh_install:
	dh_install
	# Split doc files into xdrawchem-doc package
	mkdir -p debian/xdrawchem-doc/usr/share/xdrawchem
	mv debian/xdrawchem/usr/share/xdrawchem/doc \
	   debian/xdrawchem-doc/usr/share/xdrawchem/doc
